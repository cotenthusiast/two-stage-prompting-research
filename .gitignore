# Virtual environments
.venv/
venv/
env/

# Python cache / tooling
__pycache__/
.pytest_cache/
.mypy_cache/
.ipynb_checkpoints/
*.pyc

# Environment variables
.env

# IDE files
.idea/
.cursor/
.claude/

# Data outputs
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep
data/splits/*
!data/splits/.gitkeep
data/reviews/*
!data/reviews/.gitkeep

# API response cache
.cache/

# Run outputs
runs/*
!runs/.gitkeep

# Checkpoints
checkpoints/*
!checkpoints/.gitkeep

# Report outputs (run directories are ignored; only committed structure is kept)
reports/20*/

# Logs
logs/*
!logs/.gitkeep

build/
dist/
*.egg-info/

HANDOFF.md

# Local Claude Code / terminal transcript dumps (not for version control)
claude-terminal-capture.md
.notes/
